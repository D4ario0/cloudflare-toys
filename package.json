{
  "name": "cloudflare-toys",
  "version": "0.1.2",
  "description": "Small typed helpers for Cloudflare Workers, Images, and Workers Analytics Engine.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./images/storage": {
      "types": "./dist/images/storage.d.ts",
      "import": "./dist/images/storage.js",
      "default": "./dist/images/storage.js"
    },
    "./images/variants": {
      "types": "./dist/images/variants.d.ts",
      "import": "./dist/images/variants.js",
      "default": "./dist/images/variants.js"
    },
    "./turnstile": {
      "types": "./dist/turnstile/index.d.ts",
      "import": "./dist/turnstile/index.js",
      "default": "./dist/turnstile/index.js"
    },
    "./wae": {
      "types": "./dist/wae/index.d.ts",
      "import": "./dist/wae/index.js",
      "default": "./dist/wae/index.js"
    },
    "./misc/better-auth": {
      "types": "./dist/miscellaneous/better-auth.d.ts",
      "import": "./dist/misc/better-auth.js",
      "default": "./dist/misc/better-auth.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist && bunx vite build && bunx tsc -p tsconfig.json",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "check": "bun run typecheck",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepack": "bun run build"
  },
  "keywords": [
    "cloudflare",
    "cloudflare-workers",
    "workers",
    "cloudflare-images",
    "workers-analytics-engine",
    "wae",
    "better-auth",
    "typescript",
    "edge",
    "api-client"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/D4ario0/cloudflare-toys.git"
  },
  "bugs": {
    "url": "https://github.com/D4ario0/cloudflare-toys/issues"
  },
  "homepage": "https://github.com/D4ario0/cloudflare-toys#readme",
  "author": "D4ario0",
  "license": "GPL-2.0",
  "packageManager": "pnpm@11.9.0",
  "dependencies": {
    "@better-fetch/fetch": "^1.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260704.1",
    "better-auth": "^1.6.23",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitepress": "2.0.0-alpha.17"
  },
  "peerDependencies": {
    "better-auth": ">=1.5.0 <2.0.0"
  },
  "peerDependenciesMeta": {
    "better-auth": {
      "optional": true
    }
  }
}
