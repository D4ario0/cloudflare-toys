{
  "name": "cloudflare-toys",
  "version": "0.1.4",
  "description": "Small typed helpers for Cloudflare Workers, Images, and Workers Analytics Engine.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./images/storage": {
      "types": "./dist/images/storage.d.ts",
      "import": "./dist/images/storage.js",
      "default": "./dist/images/storage.js"
    },
    "./images/variants": {
      "types": "./dist/images/variants.d.ts",
      "import": "./dist/images/variants.js",
      "default": "./dist/images/variants.js"
    },
    "./turnstile": {
      "types": "./dist/turnstile/index.d.ts",
      "import": "./dist/turnstile/index.js",
      "default": "./dist/turnstile/index.js"
    },
    "./wae": {
      "types": "./dist/wae/index.d.ts",
      "import": "./dist/wae/index.js",
      "default": "./dist/wae/index.js"
    },
    "./misc/better-auth/secondaryStorage": {
      "types": "./dist/misc/better-auth/secondaryStorage.d.ts",
      "import": "./dist/misc/better-auth/secondaryStorage.js",
      "default": "./dist/misc/better-auth/secondaryStorage.js"
    },
    "./misc/drizzle/cache": {
      "types": "./dist/misc/drizzle/cache.d.ts",
      "import": "./dist/misc/drizzle/cache.js",
      "default": "./dist/misc/drizzle/cache.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "check": "bun run typecheck",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepack": "bun run build"
  },
  "keywords": [
    "cloudflare",
    "cloudflare-workers",
    "workers",
    "cloudflare-images",
    "workers-analytics-engine",
    "wae",
    "better-auth",
    "typescript",
    "edge",
    "api-client"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/D4ario0/cloudflare-toys.git"
  },
  "bugs": {
    "url": "https://github.com/D4ario0/cloudflare-toys/issues"
  },
  "homepage": "https://github.com/D4ario0/cloudflare-toys#readme",
  "author": "D4ario0",
  "license": "GPL-2.0",
  "packageManager": "pnpm@11.9.0",
  "dependencies": {
    "@better-fetch/fetch": "^1.3.1",
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260712.1",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "tsdown": "0.22.5",
    "typescript": "^6.0.3",
    "vitepress": "2.0.0-alpha.17",
    "vitepress-plugin-llms": "^1.13.2"
  },
  "peerDependencies": {
    "better-auth": ">=1.5.0 <2.0.0",
    "drizzle-orm": ">=0.45.0 <1.0.0 || >=1.0.0-rc.0 <1.0.0"
  },
  "peerDependenciesMeta": {
    "better-auth": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    }
  }
}
