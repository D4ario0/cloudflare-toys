{
  "name": "cloudflare-toys",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    "./images": {
      "types": "./dist/images/index.d.ts",
      "default": "./dist/images/index.js"
    },
    "./images/variants": {
      "types": "./dist/images/variants.d.ts",
      "default": "./dist/images/variants.js"
    },
    "./wae": {
      "types": "./dist/wae/index.d.ts",
      "default": "./dist/wae/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bunx tsc -p tsconfig.json && bunx vite build",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@better-fetch/fetch": "^1.3.1"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "zod": "^4.4.3",
    "zod-compiler": "^1.14.0"
  }
}
